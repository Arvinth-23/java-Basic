class leet13 {
    public boolean canAliceWin(int[] nums) {
        int singledigitSum =0;
        int doubleDigitSum = 0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]<10){
                singledigitSum +=nums[i];
            }
            else{
                doubleDigitSum += nums[i];
            }
        }
        return singledigitSum!=doubleDigitSum;
    }
}
