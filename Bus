/* Bus scenario based Arry Problem which is used to check the seat is available or not */

import java.util.Scanner;
public class Bus {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);  
        System.out.println("Enter the total seat");
        int max = sc.nextInt();
        int[] seat = new int[max];
        for (int i = 0; i < max; i++) {
            System.out.print("Enter seat " + (i + 1) + ": ");
            seat[i] = sc.nextInt();
        }
        System.out.print("Enter seat number to check: ");
        int search = sc.nextInt();
        String status = "Available";
        for (int j = 0; j < max; j++) {
            if (seat[j] == search) {
                status = "Already Booked";
            }
        }
        System.out.println("Seat " + search + " is " + status);
        sc.close();
    }
}
